MONGODB_URI=mongodb://localhost:27017/timeless-electronix
ADMIN_SECRET=your-secret-code
JWT_SECRET=your-jwt-secret
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
RESEND_API_KEY=
# Inbox that receives contact/quote notifications (any address you can read).
NOTIFICATION_EMAIL=sales@timeless-electronix.com
# Sender address Resend will use. Must be from a domain you verified in Resend (not personal Gmail).
# For quick tests only, Resend allows: onboarding@resend.dev
FROM_EMAIL=noreply@timeless-electronix.com
PORT=3001
CLIENT_URL=http://localhost:5173

# Public SPA URL for sitemap entries (no trailing slash). Must match the site users open in the browser.
PUBLIC_SITE_URL=https://www.example.com

# Client build: canonical / Open Graph URLs (no trailing slash). Usually same host as PUBLIC_SITE_URL.
VITE_PUBLIC_SITE_URL=https://www.example.com

# Client: JSON API base URL (often ends with /api). Edit client/public/robots.txt Sitemap to your API origin + /sitemap.xml.
VITE_API_URL=http://localhost:3001/api

# Client (must match CLOUDINARY_CLOUD_NAME above)
VITE_CLOUDINARY_CLOUD_NAME=
